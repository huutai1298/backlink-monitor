# =============================================================================
# Backlink Monitor — Environment Variables Reference
# Copy this file to .env and fill in the values before running docker-compose.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# DB_HOST must be "mysql" (the Docker service name) when using docker-compose
# -----------------------------------------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_NAME=backlink_db
DB_USER=root
DB_PASSWORD=CHANGE_ME_db_password

# Used directly by the mysql docker-compose service
MYSQL_ROOT_PASSWORD=CHANGE_ME_db_password
MYSQL_DATABASE=backlink_db

# -----------------------------------------------------------------------------
# AUTH
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password
JWT_SECRET_KEY=CHANGE_ME_long_random_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=CHANGE_ME_bot_token
INTERNAL_GROUP_ID=-1001234567890

# -----------------------------------------------------------------------------
# CRAWLER
# -----------------------------------------------------------------------------
CRAWL_INTERVAL_MINUTES=60
CRAWL_RETRY=3
CRAWL_TIMEOUT=30
